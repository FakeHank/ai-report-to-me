{
  "name": "ai-report-to-me",
  "version": "0.2.6",
  "description": "AI-powered daily reports and wrapped summaries from your coding CLI sessions",
  "type": "module",
  "bin": {
    "aireport": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preuninstall": "aireport uninstall --hooks-only || true"
  },
  "keywords": [
    "ai",
    "report",
    "claude-code",
    "gemini-cli",
    "opencode",
    "codex",
    "daily-report",
    "wrapped",
    "coding-agent",
    "vibe-coding",
    "cli"
  ],
  "author": "hankyuan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FakeHank/ai-report-to-me"
  },
  "homepage": "https://github.com/FakeHank/ai-report-to-me",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "enquirer": "^2.4.1",
    "satori": "^0.19.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
